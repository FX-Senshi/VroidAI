# Choose the backend provider.
# openai: uses OpenAI API
# ollama: uses a local Ollama server
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# TTS settings
# voicevox: uses a local or remote VOICEVOX Engine REST API
# openai: uses OpenAI TTS
TTS_PROVIDER=voicevox

# OpenAI shared TTS
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=shimmer

# VOICEVOX shared TTS
VOICEVOX_BASE_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=72
VOICEVOX_SPEED_SCALE=0.94
VOICEVOX_PITCH_SCALE=0.02
VOICEVOX_INTONATION_SCALE=1.15
VOICEVOX_VOLUME_SCALE=1.0
VOICEVOX_PRE_PHONEME_LENGTH=0.04
VOICEVOX_POST_PHONEME_LENGTH=0.08

# Local LLM settings (Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
